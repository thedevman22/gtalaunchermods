# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ELITE_YEARLY=price_...

# Redirect URLs shown after Stripe Checkout (can point to this server)
STRIPE_SUCCESS_URL=http://localhost:4242/checkout/success
STRIPE_CANCEL_URL=http://localhost:4242/checkout/cancel

# Supabase (service role — server only, never expose to Electron app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Billing server
PORT=4242
CLIENT_ORIGIN=http://localhost:5173

# Stripe CLI for local webhook forwarding:
# stripe listen --forward-to localhost:4242/webhook
