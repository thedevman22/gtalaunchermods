# Supabase (required for auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Add http://127.0.0.1:*/auth/callback to Supabase Auth redirect URLs
# Enable Google provider in Supabase Dashboard > Authentication > Providers

# Billing API (Stripe checkout server — run `npm run server:dev`)
VITE_BILLING_API_URL=http://localhost:4242

# Optional: Stripe Customer Portal for Manage Subscription
VITE_SUBSCRIPTION_PORTAL_URL=https://billing.stripe.com/p/login/test
