# Supabase (required for auth — desktop uses VITE_*, landing uses NEXT_PUBLIC_*)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Landing page (same Supabase project as above)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Add redirect URLs in Supabase Auth:
# - http://127.0.0.1:*/auth/callback (desktop OAuth)
# - http://localhost:3000/auth/callback (landing dev)
# - https://your-domain.com/auth/callback (landing prod)

# Billing API (Stripe checkout server — run `npm run server:dev`)
VITE_BILLING_API_URL=http://localhost:4242

# ModHarbor marketing site (pricing / Stripe checkout from desktop app)
VITE_MODHARBOR_WEBSITE_URL=http://localhost:3000

# Optional: Stripe Customer Portal for Manage Subscription
VITE_SUBSCRIPTION_PORTAL_URL=https://billing.stripe.com/p/login/test

# GitHub token with repo scope — required for `npm run build:win:publish`
# GH_TOKEN=ghp_...
